{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header"><div class="container-fluid"><h1>PayXCommerce</h1></div></div>
  <div class="container-fluid">
    {% if error_warning %}<div class="alert alert-danger">{{ error_warning }}</div>{% endif %}
    <div class="alert alert-info"><strong>Webhook URL:</strong> {{ webhook_url }}</div>
    <form action="{{ action }}" method="post" data-oc-toggle="ajax">
      <div class="card"><div class="card-header"><i class="fas fa-credit-card"></i> Settings</div><div class="card-body">
        <div class="row mb-3"><label class="col-sm-2 col-form-label">Status</label><div class="col-sm-10"><select name="payment_payxcommerce_status" class="form-select"><option value="1" {% if payment_payxcommerce_status %}selected{% endif %}>Enabled</option><option value="0" {% if not payment_payxcommerce_status %}selected{% endif %}>Disabled</option></select></div></div>
        <div class="row mb-3"><label class="col-sm-2 col-form-label">Environment</label><div class="col-sm-10"><select name="payment_payxcommerce_environment" class="form-select"><option value="test" {% if payment_payxcommerce_environment != 'live' %}selected{% endif %}>Test</option><option value="live" {% if payment_payxcommerce_environment == 'live' %}selected{% endif %}>Live</option></select></div></div>
        <div class="row mb-3"><label class="col-sm-2 col-form-label">Auth Method</label><div class="col-sm-10"><select name="payment_payxcommerce_auth_method" class="form-select"><option value="hmac" {% if payment_payxcommerce_auth_method != 'bearer' %}selected{% endif %}>HMAC API Key</option><option value="bearer" {% if payment_payxcommerce_auth_method == 'bearer' %}selected{% endif %}>Developer App Bearer Token</option></select></div></div>
        {% set text_fields = [
          {'field':'base_url','label':'API Base URL','value':payment_payxcommerce_base_url},
          {'field':'public_key','label':'Public Key','value':payment_payxcommerce_public_key},
          {'field':'client_id','label':'Client ID','value':payment_payxcommerce_client_id},
          {'field':'title','label':'Payment Title','value':payment_payxcommerce_title},
          {'field':'description','label':'Payment Description','value':payment_payxcommerce_description},
          {'field':'allowed_currencies','label':'Allowed Currencies','value':payment_payxcommerce_allowed_currencies},
          {'field':'allowed_countries','label':'Allowed Countries','value':payment_payxcommerce_allowed_countries},
          {'field':'min_total','label':'Minimum Total','value':payment_payxcommerce_min_total},
          {'field':'max_total','label':'Maximum Total','value':payment_payxcommerce_max_total},
          {'field':'sort_order','label':'Sort Order','value':payment_payxcommerce_sort_order}
        ] %}
        {% for item in text_fields %}
        <div class="row mb-3"><label class="col-sm-2 col-form-label">{{ item.label }}</label><div class="col-sm-10"><input type="text" name="payment_payxcommerce_{{ item.field }}" value="{{ item.value }}" class="form-control"></div></div>
        {% endfor %}

        <div class="row mb-3"><label class="col-sm-2 col-form-label">Geo Zone</label><div class="col-sm-10"><select name="payment_payxcommerce_geo_zone_id" class="form-select"><option value="0">All Zones</option>{% for geo_zone in geo_zones %}<option value="{{ geo_zone.geo_zone_id }}" {% if geo_zone.geo_zone_id == payment_payxcommerce_geo_zone_id %}selected{% endif %}>{{ geo_zone.name }}</option>{% endfor %}</select></div></div>
        {% set status_fields = [
          {'field':'pending_status_id','label':'Pending Status','value':payment_payxcommerce_pending_status_id},
          {'field':'success_status_id','label':'Successful Status','value':payment_payxcommerce_success_status_id},
          {'field':'failed_status_id','label':'Failed Status','value':payment_payxcommerce_failed_status_id},
          {'field':'cancelled_status_id','label':'Cancelled Status','value':payment_payxcommerce_cancelled_status_id},
          {'field':'expired_status_id','label':'Expired Status','value':payment_payxcommerce_expired_status_id},
          {'field':'refunded_status_id','label':'Refunded Status','value':payment_payxcommerce_refunded_status_id},
          {'field':'chargeback_status_id','label':'Chargeback Status','value':payment_payxcommerce_chargeback_status_id}
        ] %}
        {% for item in status_fields %}
        <div class="row mb-3"><label class="col-sm-2 col-form-label">{{ item.label }}</label><div class="col-sm-10"><select name="payment_payxcommerce_{{ item.field }}" class="form-select">{% for status in order_statuses %}<option value="{{ status.order_status_id }}" {% if item.value == status.order_status_id %}selected{% endif %}>{{ status.name }}</option>{% endfor %}</select></div></div>
        {% endfor %}
        <div class="row mb-3"><label class="col-sm-2 col-form-label">Secret Key</label><div class="col-sm-10"><input type="password" name="payment_payxcommerce_secret_key" value="" placeholder="Leave blank to keep current secret" class="form-control"></div></div>
        <div class="row mb-3"><label class="col-sm-2 col-form-label">Client Secret</label><div class="col-sm-10"><input type="password" name="payment_payxcommerce_client_secret" value="" placeholder="Leave blank to keep current secret" class="form-control"></div></div>
        <div class="row mb-3"><label class="col-sm-2 col-form-label">Webhook Secret</label><div class="col-sm-10"><input type="password" name="payment_payxcommerce_webhook_secret" value="" placeholder="Leave blank to keep current secret" class="form-control"></div></div>
        <div class="text-end"><button type="submit" class="btn btn-primary">Save</button> <a href="{{ cancel }}" class="btn btn-light">Cancel</a></div>
      </div></div>
    </form>
  </div>
</div>
{{ footer }}
