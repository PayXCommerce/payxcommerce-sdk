<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="payxcommerce" translate="label" type="text" sortOrder="910" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>PayXCommerce Hosted Checkout</label>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1"><label>Enabled</label><source_model>Magento\Config\Model\Config\Source\Yesno</source_model><backend_model>PayXCommerce\Payment\Model\Config\Backend\Active</backend_model></field>
                <field id="brand_name" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1"><label>Public Brand Name</label><comment>Shown to customers. Use {brand} in title, description, and button text.</comment></field>
                <field id="title" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1"><label>Checkout Title</label></field>
                <field id="description" translate="label" type="textarea" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1"><label>Checkout Description</label></field>
                <field id="button_text" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1"><label>Checkout Button Text</label></field>
                <field id="environment" translate="label" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1"><label>Environment</label><source_model>PayXCommerce\Payment\Model\Config\Source\Environment</source_model></field>
                <field id="auth_method" translate="label" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1"><label>Authentication Method</label><source_model>PayXCommerce\Payment\Model\Config\Source\AuthMethod</source_model></field>
                <field id="base_url" translate="label" type="text" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1"><label>API Base URL</label></field>
                <field id="public_key" translate="label" type="obscure" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1"><label>Public Key</label><backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model></field>
                <field id="secret_key" translate="label" type="obscure" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1"><label>Secret Key</label><backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model></field>
                <field id="client_id" translate="label" type="obscure" sortOrder="110" showInDefault="1" showInWebsite="1" showInStore="1"><label>Developer App Client ID</label><backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model></field>
                <field id="client_secret" translate="label" type="obscure" sortOrder="120" showInDefault="1" showInWebsite="1" showInStore="1"><label>Developer App Client Secret</label><backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model></field>
                <field id="webhook_secret" translate="label" type="obscure" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="1"><label>Webhook Secret</label><backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model></field>
                <field id="allowed_currencies" translate="label" type="text" sortOrder="140" showInDefault="1" showInWebsite="1" showInStore="1"><label>Allowed Currencies</label><comment>Comma-separated ISO currency codes. Blank allows all.</comment></field>
                <field id="allowed_countries" translate="label comment" type="multiselect" sortOrder="150" showInDefault="1" showInWebsite="1" showInStore="1"><label>Allowed Countries</label><source_model>Magento\Directory\Model\Config\Source\Country</source_model><can_be_empty>1</can_be_empty><comment>Select one or more countries. Leave empty to allow all countries.</comment></field>
                <field id="min_order_total" translate="label" type="text" sortOrder="160" showInDefault="1" showInWebsite="1" showInStore="1"><label>Minimum Order Total</label></field>
                <field id="max_order_total" translate="label" type="text" sortOrder="170" showInDefault="1" showInWebsite="1" showInStore="1"><label>Maximum Order Total</label><comment>0 means no maximum.</comment></field>
                <field id="success_status" translate="label" type="select" sortOrder="180" showInDefault="1" showInWebsite="1" showInStore="1"><label>Successful Payment Status</label><source_model>Magento\Sales\Model\Config\Source\Order\Status</source_model></field>
                <field id="failed_status" translate="label" type="select" sortOrder="190" showInDefault="1" showInWebsite="1" showInStore="1"><label>Failed Payment Status</label><source_model>Magento\Sales\Model\Config\Source\Order\Status</source_model></field>
                <field id="cancelled_status" translate="label" type="select" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1"><label>Cancelled / Expired Status</label><source_model>Magento\Sales\Model\Config\Source\Order\Status</source_model></field>
                <field id="refunded_status" translate="label" type="select" sortOrder="210" showInDefault="1" showInWebsite="1" showInStore="1"><label>Refunded Status</label><source_model>Magento\Sales\Model\Config\Source\Order\Status</source_model></field>
                <field id="chargeback_status" translate="label" type="select" sortOrder="220" showInDefault="1" showInWebsite="1" showInStore="1"><label>Dispute / Chargeback Status</label><source_model>Magento\Sales\Model\Config\Source\Order\Status</source_model></field>
                <field id="debug" translate="label" type="select" sortOrder="230" showInDefault="1" showInWebsite="1" showInStore="1"><label>Debug Logging</label><source_model>Magento\Config\Model\Config\Source\Yesno</source_model></field>
                <field id="sort_order" translate="label" type="text" sortOrder="240" showInDefault="1" showInWebsite="1" showInStore="1"><label>Sort Order</label></field>
            </group>
        </section>
    </system>
</config>
