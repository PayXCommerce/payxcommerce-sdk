<div class="payxcommerce-checkout-brand" style="display:flex;align-items:center;gap:10px;margin:0 0 10px;">
  <img src="{{ icon_url }}" alt="{{ brand_name }}" style="width:32px;height:32px;border-radius:6px;">
  <strong>{{ brand_name }}</strong>
</div>
{% if description %}<p>{{ description }}</p>{% endif %}
<div class="buttons">
  <div class="pull-right">
    <a href="{{ action }}" class="btn btn-primary">{{ button_confirm }}</a>
  </div>
</div>
